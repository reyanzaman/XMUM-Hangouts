{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "cross-env NODE_ENV=production node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "npm run test:auth && npm run lint",
    "test:auth": "tsx --test tests/auth-security.test.ts",
    "generate:vapid": "web-push generate-vapid-keys --json"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "country-flag-icons": "^1.6.20",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "@vercel/node": "^5.8.24",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.0",
    "pg": "^8.21.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0"
  },
  "overrides": {
    "ajv": "8.18.0",
    "@vercel/node": {
      "path-to-regexp": "6.3.0",
      "undici": "6.27.0"
    },
    "@vercel/python-analysis": {
      "js-yaml": "5.2.1",
      "minimatch": "10.2.5",
      "smol-toml": "1.7.0"
    },
    "@vercel/static-config": {
      "ajv": "8.18.0"
    }
  }
}
