# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The public URL where this app is hosted.
# Local example: http://localhost:3000
# Vercel example: https://your-app-name.vercel.app
# Used for backup auth redirects and API-generated callback links.
APP_URL="http://localhost:3000"

# SUPABASE KEYS
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key_here"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"

# WEB PUSH (optional overrides)
# If omitted, stable free keys are derived from JWT_SECRET automatically.
# Set explicit keys only if you already have an established VAPID keypair.
VAPID_PUBLIC_KEY="your_vapid_public_key_here"
VAPID_PRIVATE_KEY="your_vapid_private_key_here"
VAPID_SUBJECT="mailto:your-admin-email@example.com"

# Random secret used by a free Supabase Cron job to run reminder delivery.
CRON_SECRET="generate_a_long_random_value"

# RESEND EMAIL DELIVERY SERVICE
RESEND_API_KEY="your_resend_api_key_here"

# ADMIN ACCOUNT ROUTING
# Used only on the server to route support emails and auto-mark the real admin account.
ADMIN_ACCOUNT_EMAIL="admin@xmu.edu.my"

# JWT_SECRET: Used for generating deterministic passwords on the backend
# Important: Set a strong, random value in production
JWT_SECRET="replace_with_a_long_random_secret"

# Optional: Enable seeded demo accounts and demo hangouts for local testing only.
# Leave this unset or false for real deployments.
VITE_ENABLE_DEMO_DATA="false"
